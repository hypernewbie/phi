{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "p":     "#fbbf24",
    "pBrt":  "#fcd34d",
    "pDim":  "#b45309",
    "pPale": "#fde68a",
    "bg0":   "#08080a",
    "bg1":   "#0d0d10",
    "bg2":   "#141418",
    "bg3":   "#1f1f26",
    "txt":   "#e4e3e9",
    "mut":   "#78768a",
    "err":   "#b06060",
    "suc":   "#50907a",
    "wrn":   "#9e8040",
    "lbg0":  "#f9f9fb",
    "lbg1":  "#f2f2f6",
    "lbg2":  "#eaeaef",
    "lbg3":  "#d4d4e0",
    "ltxt":  "#1a1820",
    "lmut":  "#70708a"
  },
  "theme": {
    "primary":           { "dark": "p",     "light": "pDim" },
    "secondary":         { "dark": "pDim",  "light": "pDim" },
    "accent":            { "dark": "p",     "light": "pDim" },
    "error":             { "dark": "err",   "light": "#8c4040" },
    "warning":           { "dark": "wrn",   "light": "#7a6020" },
    "success":           { "dark": "suc",   "light": "#2e6b56" },
    "info":              { "dark": "pBrt",  "light": "pDim" },
    "text":              { "dark": "txt",   "light": "ltxt" },
    "textMuted":         { "dark": "mut",   "light": "lmut" },
    "background":        { "dark": "bg0",   "light": "lbg0" },
    "backgroundPanel":   { "dark": "bg1",   "light": "lbg1" },
    "backgroundElement": { "dark": "bg2",   "light": "lbg2" },
    "border":            { "dark": "bg3",   "light": "lbg3" },
    "borderActive":      { "dark": "pDim",  "light": "p" },
    "borderSubtle":      { "dark": "#18181e","light": "#dcdce8" },
    "diffAdded":         { "dark": "#34d399","light": "#2e7a5e" },
    "diffRemoved":       { "dark": "#f87171","light": "#b04040" },
    "diffContext":       { "dark": "mut",   "light": "lmut" },
    "diffHunkHeader":    { "dark": "mut",   "light": "lmut" },
    "diffHighlightAdded":      { "dark": "#86efac", "light": "#16a34a" },
    "diffHighlightRemoved":    { "dark": "#fca5a5", "light": "#ef4444" },
    "diffAddedBg":             { "dark": "#0a1f14", "light": "#dcfce7" },
    "diffRemovedBg":           { "dark": "#1f0a0a", "light": "#fee2e2" },
    "diffContextBg":           { "dark": "bg1",     "light": "lbg1" },
    "diffLineNumber":          { "dark": "bg3",     "light": "lbg3" },
    "diffAddedLineNumberBg":   { "dark": "#091a10", "light": "#d1fae5" },
    "diffRemovedLineNumberBg": { "dark": "#1a0909", "light": "#ffe4e6" },
    "markdownText":           { "dark": "txt",  "light": "ltxt" },
    "markdownHeading":        { "dark": "pBrt", "light": "pDim" },
    "markdownLink":           { "dark": "p",    "light": "pDim" },
    "markdownLinkText":       { "dark": "pBrt", "light": "pDim" },
    "markdownCode":           { "dark": "pPale","light": "pDim" },
    "markdownBlockQuote":     { "dark": "mut",  "light": "lmut" },
    "markdownEmph":           { "dark": "pDim", "light": "pDim" },
    "markdownStrong":         { "dark": "pBrt", "light": "pDim" },
    "markdownHorizontalRule": { "dark": "bg3",  "light": "lbg3" },
    "markdownListItem":       { "dark": "p",    "light": "pDim" },
    "markdownListEnumeration":{ "dark": "pDim", "light": "pDim" },
    "markdownImage":          { "dark": "p",    "light": "pDim" },
    "markdownImageText":      { "dark": "pBrt", "light": "pDim" },
    "markdownCodeBlock":      { "dark": "txt",  "light": "ltxt" },
    "syntaxComment":    { "dark": "#505060", "light": "#888898" },
    "syntaxKeyword":    { "dark": "pBrt",    "light": "pDim" },
    "syntaxFunction":   { "dark": "p",       "light": "pDim" },
    "syntaxVariable":   { "dark": "txt",     "light": "ltxt" },
    "syntaxString":     { "dark": "pPale",   "light": "pDim" },
    "syntaxNumber":     { "dark": "pBrt",    "light": "pDim" },
    "syntaxType":       { "dark": "pDim",    "light": "pDim" },
    "syntaxOperator":   { "dark": "p",       "light": "pDim" },
    "syntaxPunctuation":{ "dark": "#909098", "light": "#808090" }
  }
}
